# Example terraform.tfvars — copy to terraform.tfvars and fill in

project_id    = "your-gcp-project-id"
region        = "us-central1"
gemini_api_key = "your-gemini-api-key"
backend_image = "gcr.io/your-gcp-project-id/pitwall-backend:latest"
web_image     = "gcr.io/your-gcp-project-id/pitwall-web:latest"
